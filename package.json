{
  "name": "just-management-monorepo",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:all": "npm run dev",
    "build": "npm run build -w frontend && npm run build -w backend && npm run sync:dist",
    "sync:dist": "node scripts/sync-dist.mjs",
    "build:all": "npm run build",
    "install:all": "npm install",
    "typecheck": "npm run typecheck -w frontend",
    "test:frontend": "npm run test:frontend -w frontend",
    "start": "npm run start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
