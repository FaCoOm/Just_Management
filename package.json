{
  "name": "just-management-monorepo",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "preinstall": "node scripts/clean-stale-esbuild.mjs",
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:all": "npm run dev",
    "prebuild": "npm install --include=dev --legacy-peer-deps",
    "build": "node scripts/ensure-build-deps.mjs && npm run build:app",
    "build:app": "npm run build -w frontend && npm run build -w backend && npm run sync:dist",
    "sync:dist": "node scripts/sync-dist.mjs",
    "build:all": "npm run build",
    "install:all": "npm install",
    "typecheck": "npm run typecheck -w frontend",
    "test:frontend": "npm run test:frontend -w frontend",
    "start": "npm run start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
