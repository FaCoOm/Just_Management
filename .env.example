# ==============================================================================
# Just Management - Frontend Environment Variables Template
# Copy this file to '.env' in the root directory and configure for your deployment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🌐 CURRENT REST API RUNTIME
# ------------------------------------------------------------------------------
# Base URL of the current Express/Prisma REST backend.
# Leave EMPTY for same-origin deployments (Vite dev proxy in dev, single-origin
# Express in production). Override only when frontend and backend run on
# separate origins.
VITE_TRACK_B_API_URL=


# ------------------------------------------------------------------------------
# 🔗 WITHONE CONNECT WIDGET INTEGRATION (Frontend)
# ------------------------------------------------------------------------------
# The backend authorization endpoint that issues short-lived Connect AuthKit tokens
# for the interactive connect-integration widget in the Settings panel.
VITE_ONE_AUTH_TOKEN_URL=/api/one/auth-token
