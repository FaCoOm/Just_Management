# ==============================================================================
# Just Management - Track Selection & Frontend Environment Variables Template
# Copy this file to '.env' in the root directory and configure for your deployment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🏁 TRACK SELECTION
# ------------------------------------------------------------------------------
# Selects which backend data layer to use.
#   - "A" : Supabase (Track A schema-intent reference)
#   - "B" : REST API Express/Prisma backend (Active Canonical Track B)
VITE_TRACK=B


# ------------------------------------------------------------------------------
# ☁️ TRACK A CONFIGURATION (Supabase Reference)
# ------------------------------------------------------------------------------
# Only needed if VITE_TRACK is set to "A" or left blank.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key


# ------------------------------------------------------------------------------
# ⚡ TRACK B CONFIGURATION (Express.js REST API Backend)
# ------------------------------------------------------------------------------
# Base URL of the Track B Express/Prisma backend.
# Leave EMPTY for same-origin deployments (Vite dev proxy in dev, single-origin
# Express in production). Override only when frontend and backend run on
# separate origins.
VITE_TRACK_B_API_URL=


# ------------------------------------------------------------------------------
# 🔗 WITHONE CONNECT WIDGET INTEGRATION (Frontend)
# ------------------------------------------------------------------------------
# The backend authorization endpoint that issues short-lived Connect AuthKit tokens
# for the interactive connect-integration widget in the Settings panel.
VITE_ONE_AUTH_TOKEN_URL=/api/one/auth-token
