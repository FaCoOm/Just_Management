# Track B Frontend Environment Variables
# Copy to .env and configure for your deployment mode.

# ---- Track Selection ----
# "A" = Supabase (default)
# "B" = REST API backend
VITE_TRACK=B

# ---- Track A (Supabase) ----
# Only needed when VITE_TRACK is unset or "A".
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Track B (REST API) ----
# Base URL of the Express/Prisma backend.
# In development, Vite proxy handles /api calls so this can point at localhost.
VITE_TRACK_B_API_URL=http://localhost:3001