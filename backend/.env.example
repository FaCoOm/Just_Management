# Track B Backend Environment Variables
# Copy to .env and fill in values

# Azure Database connection string
DATABASE_URL="postgresql://user:password@host:5432/m_management"

# Express server
PORT=3001

# Supabase (for potential sync back to Track A)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key