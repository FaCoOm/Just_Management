# ==============================================================================
# Just Management - Track B Backend Environment Variables Template
# Copy this file to '.env' inside the 'backend' directory and fill in the values.
# ==============================================================================

# ------------------------------------------------------------------------------
# 💾 DATABASE CONFIGURATION (PostgreSQL)
# ------------------------------------------------------------------------------

# Option A: Local Development Database (Recommended for Offline/Fast Development)
# Run a local PostgreSQL instance (e.g. via Docker or standard system install).
# Command to run local Postgres in Docker:
#   docker run --name just-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=just_management -p 5432:5432 -d postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/just_management"

# Option B: Azure PostgreSQL Flexible Server (Cloud Production/Staging)
# Requires 'sslmode=require' for Azure TLS enforcement. Obtain from the Azure portal.
# DATABASE_URL="postgresql://user:password@HOST.postgres.database.azure.com:5432/m_management?sslmode=require"


# ------------------------------------------------------------------------------
# 🖥️ EXPRESS SERVER CONFIGURATION
# ------------------------------------------------------------------------------
PORT=3001
SLOW_REQUEST_THRESHOLD_MS=500
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173


# ------------------------------------------------------------------------------
# 🌐 WITHONE UNIFIED API INTEGRATION (Gmail / Google Sheets / OTAs)
# ------------------------------------------------------------------------------

# Mode-aware connection key used for local development/testing to authenticate
# third-party integrations (e.g., retrieving emails, reading/writing sheets).
# Obtain this from your WithOne dashboard -> Connections.
ONE_CONNECTION_KEY=conn_dev_replace_me

# Server-side WithOne secret key. Never expose this to the frontend.
ONE_SECRET_KEY=sk_live_replace_me

# Base URL for the WithOne API. Override only if you are running against a sandbox or mock API.
ONE_API_BASE=https://api.withone.ai/v1

# HMAC signing secret for incoming /api/one/webhook events.
ONE_WEBHOOK_SECRET=whsec_replace_me

# Dev-only shared secret to access /api/one/auth-token until full authentication is set up.
# Pass this in the 'x-dev-token' header when requesting AuthKit connection tokens.
ONE_DEV_TOKEN=dev-only-shared-secret

# Default identity type when the frontend AuthKit connection widget requests a token.
ONE_AUTHKIT_DEFAULT_IDENTITY_TYPE=user


# ------------------------------------------------------------------------------
# 📊 INGESTION PIPELINE & GOOGLE SERVICES
# ------------------------------------------------------------------------------

# Main switch to enable/disable the background folder and file ingestion pipeline.
INGEST_PIPELINE_ENABLED=true

# Google Sheets ingestion provider feature flag.
# Options:
#   - 'google-sheets-direct' : Connects directly via service-account credentials (requires GOOGLE_SERVICE_ACCOUNT_FILE).
#   - 'withone'              : Uses WithOne unified API passthrough (uses ONE_CONNECTION_KEY).
INGEST_SHEETS_PROVIDER=google-sheets-direct

# Google Sheets service account credentials JSON file (required for 'google-sheets-direct').
# Keep this file secure and NEVER commit it to source control.
GOOGLE_SERVICE_ACCOUNT_FILE=../credentials.json

# Fallback Google Application Credentials environment variable.
# GOOGLE_APPLICATION_CREDENTIALS=../credentials.json

# Spreadsheet ID used for direct sheet-based ingestion requests.
GOOGLE_SHEETS_SPREADSHEET_ID=your-google-sheets-spreadsheet-id


# ------------------------------------------------------------------------------
# 📁 WATCHED DIRECTORY & LOCAL INGESTION
# ------------------------------------------------------------------------------

# Absolute path to the folder to watch for files. Ingest watches two subfolders:
#   - listings/inbox
#   - reservations/inbox
# Files placed in these folders are automatically parsed, processed, and archived.
# M_MANAGEMENT_IMPORT_ROOT=C:\MManagement\imports

# Deprecated watcher variable alias kept for backward compatibility (prefer M_MANAGEMENT_IMPORT_ROOT).
# M_MANAGEMENT_WATCH_DIR=C:\MManagement\imports

# Set to true only if you want the listings parser to automatically create properties
# and rooms when seeding inventory from trusted listings files. Default is false.
M_MANAGEMENT_LISTINGS_CREATE_INVENTORY=false

# Root path for seed and import source data. Used by CLI seed and reset tools.
M_MANAGEMENT_BUILTIN_SOURCE_DIR=../database_design

# Email attachment import configuration for OTA synchronization.
M_MANAGEMENT_EMAIL_IMPORT_ENABLED=false
M_MANAGEMENT_EMAIL_IMPORT_PROVIDER=gmail
M_MANAGEMENT_EMAIL_IMPORT_QUERY="has:attachment filename:csv newer_than:30d"
