# Track B Backend Environment Variables
# Copy to .env and fill in values

# Azure PostgreSQL Flexible Server connection string
# Requires sslmode=require for Azure TLS enforcement.
# Use the connection string from Azure portal -> Connection strings -> psql.
DATABASE_URL="postgresql://user:password@HOST.postgres.database.azure.com:5432/m_management?sslmode=require"

# Express server
PORT=3001

# Google Sheets service account key file (keep out of source control)
GOOGLE_SERVICE_ACCOUNT_FILE=../credentials.json

# Optional default spreadsheet id for sheet-based ingestion requests
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Ingestion pipeline scaffolding
INGEST_PIPELINE_ENABLED=true

# Runtime import root for watched-folder imports.
# Files are read from listings/inbox and reservations/inbox, then moved to
# processed or quarantine by the folder-watch pipeline run.
# M_MANAGEMENT_IMPORT_ROOT=C:\MManagement\imports
# Deprecated alias kept for one release; prefer M_MANAGEMENT_IMPORT_ROOT.
# M_MANAGEMENT_WATCH_DIR=C:\MManagement\imports

# Listing imports must not create properties/rooms by default. Set true only
# when intentionally seeding inventory from trusted listing files.
M_MANAGEMENT_LISTINGS_CREATE_INVENTORY=false

# Built-in seed/import source directory for future default data import.
M_MANAGEMENT_BUILTIN_SOURCE_DIR=../database_design

# Optional email attachment import configuration for future sync.
M_MANAGEMENT_EMAIL_IMPORT_ENABLED=false
# M_MANAGEMENT_EMAIL_IMPORT_PROVIDER=gmail

# ---- Withone API integration ----
# Server-side withone secret (live or test). Never expose to frontend.
ONE_SECRET_KEY=sk_live_replace_me

# Base URL for withone API. Override only if you are running against a sandbox.
ONE_API_BASE=https://api.withone.ai/v1

# Default identity type when the frontend AuthKit widget asks for a token.
ONE_AUTHKIT_DEFAULT_IDENTITY_TYPE=user

# HMAC signing secret for inbound /api/one/webhook events.
ONE_WEBHOOK_SECRET=whsec_replace_me

# Dev-only shared secret to access /api/one/auth-token until Sprint 2 auth lands.
# Required header on requests is x-dev-token.
ONE_DEV_TOKEN=dev-only-shared-secret

# Sheets ingestion provider feature flag.
# Values: google-sheets-direct (default, service-account) | withone (passthrough)
INGEST_SHEETS_PROVIDER=google-sheets-direct
