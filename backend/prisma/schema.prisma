// Prisma schema mirroring Track A balanced-core v1 schema.
// Track A SQL remains in supabase/migrations/*.sql.
// Track B migrations are generated from this schema for Azure PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model properties {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  total_rooms Int      @default(0)
  location    String   @default("")
  status      String   @default("active")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  rooms              rooms[]
  guests             guests[]
  guest_requests     guest_requests[]
  maintenance_issues maintenance_issues[]
  reservations       reservations[]
}

model rooms {
  id          String   @id @default(uuid()) @db.Uuid
  property_id String   @db.Uuid
  room_number String
  room_name   String   @default("")
  room_type   String   @default("Standard")
  status      String   @default("Vacant")
  passcode    String   @default("")
  floor       Int      @default(1)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  property                     properties                    @relation(fields: [property_id], references: [id], onDelete: Restrict)
  guests                       guests[]
  guest_requests               guest_requests[]
  listing_room_mappings        listing_room_mappings[]
  maintenance_issues           maintenance_issues[]
  primary_reservations         reservations[]                @relation("reservation_primary_room")
  reservation_room_allocations reservation_room_allocations[]

  @@unique([id, property_id])
  @@index([property_id])
}

model guests {
  id              String    @id @default(uuid()) @db.Uuid
  property_id     String    @db.Uuid
  room_id         String?   @db.Uuid
  guest_name      String
  eta             DateTime? @db.Timestamptz(6)
  etd             DateTime? @db.Timestamptz(6)
  check_in_status String    @default("Pending")
  booking_source  String    @default("Direct")
  is_vip          Boolean   @default(false)
  guest_count     Int       @default(1)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)

  property                           properties                           @relation(fields: [property_id], references: [id], onDelete: Restrict)
  room                               rooms?                               @relation(fields: [room_id], references: [id], onDelete: Restrict)
  guest_requests                     guest_requests[]
  legacy_guest_reservation_backfills legacy_guest_reservation_backfills[]

  @@index([property_id, created_at])
  @@index([room_id])
}

model guest_requests {
  id             String   @id @default(uuid()) @db.Uuid
  guest_id       String   @db.Uuid
  room_id        String   @db.Uuid
  request_type   String
  notes          String   @default("")
  is_completed   Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  reservation_id String?  @db.Uuid
  property_id    String?  @db.Uuid

  guest       guests        @relation(fields: [guest_id], references: [id], onDelete: Restrict)
  property    properties?   @relation(fields: [property_id], references: [id], onDelete: SetNull)
  reservation reservations? @relation(fields: [reservation_id], references: [id], onDelete: SetNull)
  room        rooms         @relation(fields: [room_id], references: [id], onDelete: Restrict)

  @@index([guest_id])
  @@index([property_id])
  @@index([reservation_id])
}

model maintenance_issues {
  id          String   @id @default(uuid()) @db.Uuid
  property_id String   @db.Uuid
  room_id     String?  @db.Uuid
  title       String
  description String   @default("")
  severity    String   @default("Low")
  status      String   @default("Open")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  property properties @relation(fields: [property_id], references: [id], onDelete: Restrict)
  room     rooms?     @relation(fields: [room_id], references: [id], onDelete: Restrict)

  @@index([property_id, status, created_at])
  @@index([status, created_at])
}

model channels {
  id         String   @id @default(uuid()) @db.Uuid
  slug       String   @unique
  display_name String
  status     String   @default("active")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  external_accounts          external_accounts[]
  provider_reservation_import_rows provider_reservation_import_rows[]
  reservation_external_refs  reservation_external_refs[]
}

model external_accounts {
  id                   String    @id @default(uuid()) @db.Uuid
  channel_id           String    @db.Uuid
  account_key          String
  display_name         String
  status               String    @default("active")
  archived_at          DateTime? @db.Timestamptz(6)
  last_synced_at       DateTime? @db.Timestamptz(6)
  last_sync_started_at DateTime? @db.Timestamptz(6)
  last_sync_error      String?
  sync_metadata        Json      @default("{}")
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  channel                          channels                           @relation(fields: [channel_id], references: [id], onDelete: Restrict)
  channel_listing_aliases          channel_listing_aliases[]
  channel_listings                 channel_listings[]
  provider_reservation_import_rows provider_reservation_import_rows[]
  reservation_external_refs        reservation_external_refs[]

  @@unique([channel_id, account_key])
  @@unique([id, channel_id])
  @@index([channel_id])
}

model channel_listings {
  id                  String    @id @default(uuid()) @db.Uuid
  external_account_id String    @db.Uuid
  provider_listing_id String
  owner               String    @default("mujo")
  title               String
  internal_name       String?
  listing_type        String    @default("home")
  location            String    @default("")
  status              String    @default("listed")
  public_url          String?
  host_editor_url     String?
  extracted_at        DateTime? @db.Timestamptz(6)
  last_synced_at      DateTime? @db.Timestamptz(6)
  last_seen_at        DateTime? @db.Timestamptz(6)
  source_metadata     Json      @default("{}")
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  external_account                 external_accounts                  @relation(fields: [external_account_id], references: [id], onDelete: Restrict)
  channel_listing_aliases          channel_listing_aliases[]
  listing_room_mappings            listing_room_mappings[]
  provider_reservation_import_rows provider_reservation_import_rows[]
  reservation_external_refs        reservation_external_refs[]

  @@unique([external_account_id, provider_listing_id])
  @@unique([provider_listing_id])
  @@unique([id, external_account_id])
  @@index([owner])
}

model channel_listing_aliases {
  id                 String    @id @default(uuid()) @db.Uuid
  channel_listing_id String    @db.Uuid
  external_account_id String   @db.Uuid
  alias_value        String
  alias_type         String    @default("manual")
  status             String    @default("active")
  archived_at        DateTime? @db.Timestamptz(6)
  raw_metadata       Json      @default("{}")
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  channel_listing channel_listings  @relation(fields: [channel_listing_id, external_account_id], references: [id, external_account_id], onDelete: Cascade)
  external_account external_accounts @relation(fields: [external_account_id], references: [id], onDelete: Restrict)

  @@unique([channel_listing_id, alias_value])
  @@index([external_account_id, alias_value])
}

model listing_room_mappings {
  id                 String    @id @default(uuid()) @db.Uuid
  channel_listing_id String    @db.Uuid
  room_id            String    @db.Uuid
  mapping_role       String    @default("full_occupancy")
  status             String    @default("active")
  sort_order         Int       @default(1)
  notes              String    @default("")
  archived_at        DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  channel_listing channel_listings @relation(fields: [channel_listing_id], references: [id], onDelete: Cascade)
  room            rooms            @relation(fields: [room_id], references: [id], onDelete: Restrict)

  @@index([channel_listing_id, room_id])
}

model reservations {
  id                String   @id @default(uuid()) @db.Uuid
  property_id       String   @db.Uuid
  primary_room_id   String?  @db.Uuid
  status            String   @default("pending")
  check_in_date     DateTime @db.Date
  check_out_date    DateTime @db.Date
  guest_name        String
  guest_phone       String?
  guest_email       String?
  adult_count       Int      @default(1)
  child_count       Int      @default(0)
  infant_count      Int      @default(0)
  guest_count       Int      @default(1)
  operational_notes String   @default("")
  guest_notes       String   @default("")
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  property                      properties                    @relation(fields: [property_id], references: [id], onDelete: Restrict)
  primary_room                  rooms?                        @relation("reservation_primary_room", fields: [primary_room_id, property_id], references: [id, property_id], onDelete: Restrict)
  guest_requests                guest_requests[]
  legacy_guest_reservation_backfills legacy_guest_reservation_backfills[]
  provider_reservation_import_rows provider_reservation_import_rows[]
  reservation_external_refs     reservation_external_refs[]
  reservation_room_allocations  reservation_room_allocations[]
  tax_export_items              tax_export_items[]

  @@index([property_id, check_in_date, check_out_date])
  @@index([status])
  @@index([property_id, status, check_in_date, check_out_date])
  @@index([status, check_in_date, check_out_date])
  @@index([check_in_date, check_out_date])
  @@index([created_at])
}

model reservation_external_refs {
  id                      String    @id @default(uuid()) @db.Uuid
  reservation_id          String    @db.Uuid
  channel_id              String    @db.Uuid
  external_account_id     String?   @db.Uuid
  channel_listing_id      String?   @db.Uuid
  provider_reservation_id String?
  confirmation_code       String?
  raw_status              String?
  source_status           String?
  booked_at               DateTime? @db.Timestamptz(6)
  source_created_at       DateTime? @db.Timestamptz(6)
  source_updated_at       DateTime? @db.Timestamptz(6)
  last_synced_at          DateTime? @db.Timestamptz(6)
  payload_metadata        Json      @default("{}")
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  reservation      reservations       @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  channel          channels           @relation(fields: [channel_id], references: [id], onDelete: Restrict)
  external_account external_accounts? @relation(fields: [external_account_id, channel_id], references: [id, channel_id], onDelete: Restrict)
  channel_listing  channel_listings?  @relation(fields: [channel_listing_id, external_account_id], references: [id, external_account_id], onDelete: Restrict)

  @@index([reservation_id])
  @@index([channel_listing_id])
  @@index([channel_id, external_account_id, provider_reservation_id], map: "refs_provider_res_idx")
  @@index([channel_id, external_account_id, confirmation_code], map: "refs_confirmation_idx")
}

model reservation_room_allocations {
  id              String   @id @default(uuid()) @db.Uuid
  reservation_id  String   @db.Uuid
  room_id         String   @db.Uuid
  allocation_role String   @default("stay")
  sort_order      Int      @default(1)
  notes           String   @default("")
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  reservation reservations @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  room        rooms        @relation(fields: [room_id], references: [id], onDelete: Restrict)

  @@unique([reservation_id, room_id])
  @@index([room_id])
}

model legacy_guest_reservation_backfills {
  id                    String   @id @default(uuid()) @db.Uuid
  guest_id              String   @db.Uuid
  reservation_id        String   @db.Uuid
  source_check_in_status String  @default("")
  source_booking_source String   @default("")
  field_mapping         Json     @default("{}")
  backfilled_at         DateTime @default(now()) @db.Timestamptz(6)
  created_at            DateTime @default(now()) @db.Timestamptz(6)

  guest       guests        @relation(fields: [guest_id], references: [id], onDelete: Restrict)
  reservation reservations  @relation(fields: [reservation_id], references: [id], onDelete: Cascade)

  @@unique([guest_id])
  @@unique([reservation_id])
  @@index([reservation_id])
}

model provider_reservation_import_rows {
  id                          String    @id @default(uuid()) @db.Uuid
  channel_id                  String    @db.Uuid
  external_account_id         String    @db.Uuid
  source_file                 String
  source_row_number           Int?
  provider_reservation_id     String?
  confirmation_code           String?
  raw_status                  String    @default("")
  guest_name                  String
  guest_contact               String?
  adult_count                 Int       @default(0)
  child_count                 Int       @default(0)
  infant_count                Int       @default(0)
  guest_count                 Int       @default(0)
  check_in_date               DateTime  @db.Date
  check_out_date              DateTime  @db.Date
  booked_at                   DateTime? @db.Timestamptz(6)
  provider_listing_id         String?
  listing_alias_value         String?
  raw_payload                 Json      @default("{}")
  resolved_channel_listing_id String?   @db.Uuid
  resolution_status           String    @default("pending")
  resolution_method           String?
  resolution_notes            String    @default("")
  reservation_id              String?   @db.Uuid
  created_at                  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  channel                  channels           @relation(fields: [channel_id], references: [id], onDelete: Restrict)
  external_account         external_accounts  @relation(fields: [external_account_id, channel_id], references: [id, channel_id], onDelete: Restrict)
  resolved_channel_listing channel_listings?  @relation(fields: [resolved_channel_listing_id, external_account_id], references: [id, external_account_id], onDelete: Restrict)
  reservation              reservations?      @relation(fields: [reservation_id], references: [id], onDelete: SetNull)

  @@index([resolution_status])
  @@index([resolved_channel_listing_id])
  @@index([external_account_id, source_file, source_row_number])
  @@index([channel_id, external_account_id, confirmation_code], map: "provider_import_confirmation_idx")
  @@index([channel_id, external_account_id, provider_reservation_id], map: "provider_import_provider_res_idx")
}

model sync_runs {
  id                String    @id @default(uuid()) @db.Uuid
  source_type       String
  source_account    String?
  endpoint          String
  is_dry_run        Boolean   @default(false)
  status            String    @default("started")
  processed_count   Int       @default(0)
  created_count     Int       @default(0)
  updated_count     Int       @default(0)
  skipped_count     Int       @default(0)
  dead_letter_count Int       @default(0)
  started_at        DateTime  @default(now()) @db.Timestamptz(6)
  finished_at       DateTime? @db.Timestamptz(6)
  config_snapshot   Json      @default("{}")

  sync_dead_letters sync_dead_letters[]
}

model sync_dead_letters {
  id                 String    @id @default(uuid()) @db.Uuid
  sync_run_id        String    @db.Uuid
  source_file        String?
  source_row_number  Int?
  failure_code       String
  failure_reason     String
  normalized_payload Json      @default("{}")
  created_at         DateTime  @default(now()) @db.Timestamptz(6)

  sync_run sync_runs @relation(fields: [sync_run_id], references: [id], onDelete: Cascade)

  @@index([sync_run_id])
  @@index([source_file, source_row_number])
}

model integration_connections {
  id             String    @id @default(uuid()) @db.Uuid
  user_id        String
  identity_type  String    @default("user")
  platform       String
  connection_key String    @unique
  display_name   String?
  environment    String    @default("live")
  status         String    @default("active")
  last_used_at   DateTime? @db.Timestamptz(6)
  last_error     String?
  metadata       Json      @default("{}")
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)

  @@index([user_id, platform])
  @@index([status])
}

model watched_files {
  id                String    @id @default(uuid()) @db.Uuid
  watch_dir         String
  relative_path     String
  size_bytes        BigInt
  mtime             DateTime  @db.Timestamptz(6)
  content_sha256    String
  last_seen_at      DateTime  @default(now()) @db.Timestamptz(6)
  last_processed_at DateTime? @db.Timestamptz(6)
  last_sync_run_id  String?   @db.Uuid
  status            String    @default("seen")
  failure_reason    String?
  target_kind       String    @default("unknown")

  @@unique([watch_dir, relative_path, content_sha256])
  @@index([status])
  @@index([watch_dir, target_kind, status, last_seen_at])
}

model email_import_messages {
  id                  String    @id @default(uuid()) @db.Uuid
  connection_key      String
  provider            String    @default("gmail")
  provider_message_id String
  thread_id           String?
  internal_date       DateTime? @db.Timestamptz(6)
  subject             String?
  from_address        String?
  attachment_filename String?
  attachment_size     BigInt?
  attachment_sha256   String?
  status              String    @default("seen")
  last_sync_run_id    String?   @db.Uuid
  failure_reason      String?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([connection_key, provider_message_id, attachment_sha256])
  @@index([status])
}

model seed_batches {
  id              String    @id @default(uuid()) @db.Uuid
  source_dir      String
  manifest_sha256 String
  status          String    @default("started")
  sync_run_id     String?   @db.Uuid
  started_at      DateTime  @default(now()) @db.Timestamptz(6)
  finished_at     DateTime? @db.Timestamptz(6)
  notes           String?

  @@index([source_dir, status])
}


// =============================================================================
// Tax Export Models
// =============================================================================

model tax_export_settings {
  id                    String   @id @default(uuid()) @db.Uuid
  default_buyer_label   String   @default("Khách lẻ không lấy hóa đơn")
  default_payment_method String  @default("Chuyển khoản")
  default_unit          String   @default("Đêm")
  default_vat_rate      Int      @default(8)
  service_name_template String   @default("Dịch vụ thuê phòng ({check_in} - {check_out})")
  schedule_enabled      Boolean  @default(false)
  schedule_time         String   @default("18:00")
  schedule_timezone     String   @default("Asia/Ho_Chi_Minh")
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

model tax_export_jobs {
  id              String    @id @default(uuid()) @db.Uuid
  checkout_date   DateTime  @db.Date
  status          String    @default("pending")
  total_items     Int       @default(0)
  exported_count  Int       @default(0)
  failed_count    Int       @default(0)
  skipped_count   Int       @default(0)
  review_count    Int       @default(0)
  triggered_by    String    @default("manual")
  started_at      DateTime  @default(now()) @db.Timestamptz(6)
  completed_at    DateTime? @db.Timestamptz(6)
  error_message   String?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)

  items tax_export_items[]

  @@unique([checkout_date, status])
  @@index([checkout_date])
  @@index([status])
}

model tax_export_items {
  id                  String    @id @default(uuid()) @db.Uuid
  job_id              String    @db.Uuid
  reservation_id      String    @db.Uuid
  invoice_number      String
  invoice_date        String
  buyer_label         String    @default("Khách lẻ không lấy hóa đơn")
  payment_method      String    @default("Chuyển khoản")
  service_description String
  unit                String    @default("Đêm")
  quantity            Int
  unit_price          Float
  total_amount        Float
  vat_rate            Int       @default(8)
  vat_amount          Float
  status              String    @default("pending")
  needs_review_reason String?
  guest_name          String
  property_name       String
  check_in_date       String
  check_out_date      String
  confirmation_code   String?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)

  job         tax_export_jobs @relation(fields: [job_id], references: [id], onDelete: Cascade)
  reservation reservations    @relation(fields: [reservation_id], references: [id], onDelete: Restrict)

  @@index([job_id])
  @@index([reservation_id])
  @@index([status])
}
