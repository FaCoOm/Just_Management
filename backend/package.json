{
  "name": "m-management-track-b",
  "version": "1.0.0",
  "description": "Track B: Azure/Node/Prisma backend for M_Management",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:diff:init": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "db:studio": "prisma studio",
    "db:verify:migration": "node scripts/verify-azure-migration.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/cors": "^2.8.17",
    "prisma": "^6.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}