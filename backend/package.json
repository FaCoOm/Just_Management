{
  "name": "m-management-backend",
  "version": "1.0.0",
  "description": "Express/Prisma/Azure backend for Just Management",
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:diff:init": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "db:studio": "prisma studio",
    "db:verify:migration": "node scripts/verify-azure-migration.mjs",
    "classify:listings": "tsx scripts/classify-airbnb-listings.ts",
    "verify-ingestion": "tsx scripts/verify-ingestion.ts",
    "verify:all": "npm run build && npm run verify-ingestion",
    "seed:rooms-sot": "tsx scripts/seed-rooms-sot.ts",
    "seed:rooms-sot:strict": "tsx scripts/seed-rooms-sot.ts --strict",
    "seed:listings-sot": "tsx scripts/seed-listings-sot.ts",
    "seed:listings-sot:apply": "tsx scripts/seed-listings-sot.ts --apply",
    "merge:surplus-rooms": "tsx scripts/merge-surplus-rooms.ts",
    "seed:reservations-sot": "tsx scripts/seed-reservations-sot.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "chokidar": "^5.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^154.0.0",
    "multer": "^2.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "fast-check": "^3.23.2",
    "prisma": "^6.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
