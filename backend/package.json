{
  "name": "m-management-track-b",
  "version": "1.0.0",
  "description": "Track B: Azure/Node/Prisma backend for M_Management",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --import ./test/setup.ts --test \"test/**/*.test.ts\" \"test/**/*.spec.ts\" \"src/**/*.test.ts\" \"src/**/*.spec.ts\"",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:diff:init": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "db:studio": "prisma studio",
    "db:verify:migration": "node scripts/verify-azure-migration.mjs",
    "classify:listings": "tsx scripts/classify-airbnb-listings.ts",
    "verify-ingestion": "tsx scripts/verify-ingestion.ts",
    "verify:all": "npm run build && npm run verify-ingestion"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "chokidar": "^5.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^154.0.0",
    "multer": "^2.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "prisma": "^6.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
